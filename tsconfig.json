{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",

    "target": "ES2020",
    "lib": ["es2020"],

    "module": "nodenext",
    "moduleResolution": "nodenext",

    "strict": true,

    "esModuleInterop": true,

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "emitDeclarationOnly": false,

    "types": ["node"],

    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts"]
}
