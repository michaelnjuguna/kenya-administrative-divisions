{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ES2020",
    "module": "commonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "./dist/types",
    "emitDeclarationOnly": false,
    "rootDir": "./src",
    "lib": ["es2016"],
    "sourceMap": true,
    "types": ["jest", "node"],
  },
  "include": ["src/**/*.ts"],
}
